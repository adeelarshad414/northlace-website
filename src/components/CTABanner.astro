---
interface Props {
  buttonHref: string;
  buttonText: string;
  heading: string;
}

const { buttonHref, buttonText, heading } = Astro.props;
---

<section
  class="bg-northlace-50 py-16 md:py-24"
  aria-labelledby="cta-banner-heading"
>
  <div
    class="mx-auto flex max-w-6xl flex-col gap-6 px-6 md:flex-row md:items-center md:justify-between"
  >
    <h2 id="cta-banner-heading" class="max-w-2xl text-h2 text-northlace-900">
      {heading}
    </h2>
    <a
      class="inline-flex w-fit rounded-md border border-northlace-700 px-5 py-3 text-body text-northlace-700 hover:bg-northlace-700 hover:text-text-on-dark"
      href={buttonHref}
    >
      {buttonText}
    </a>
  </div>
</section>
