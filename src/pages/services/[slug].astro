---
import { getCollection } from "astro:content";

import CTABanner from "../../components/CTABanner.astro";
import Layout from "../../layouts/Layout.astro";
import {
  getServicePillar,
  servicePillars,
  type ServicePillarId,
} from "../../data/services";
import { buildBreadcrumbJsonLd } from "../../lib/seo";

export const getStaticPaths = () =>
  servicePillars.map((pillar) => ({ params: { slug: pillar.id } }));

const pillar = getServicePillar(Astro.params.slug as ServicePillarId);
if (!pillar) throw new Error("Unknown service pillar");

const related = (await getCollection("case-studies"))
  .filter(
    (entry) => !entry.data.draft && entry.data.pillars.includes(pillar.id),
  )
  .slice(0, 2);
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
---

<Layout
  title={`${pillar.name} | Northlace`}
  description={pillar.description}
  canonicalPath={pillar.href}
  structuredData={buildBreadcrumbJsonLd(siteUrl, [
    { name: "Home", path: "/" },
    { name: "Services", path: "/services" },
    { name: pillar.name, path: pillar.href },
  ])}
>
  <section class="bg-northlace-900 py-16 text-text-on-dark md:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <a class="text-small text-northlace-100 underline" href="/services"
        >Services</a
      >
      <h1 class="mt-4 text-h1">{pillar.name}</h1>
      <p class="mt-5 max-w-3xl text-body text-northlace-100">{pillar.value}</p>
    </div>
  </section>

  <section
    class="mx-auto grid max-w-6xl gap-10 px-6 py-16 md:grid-cols-2 md:py-24"
  >
    <div>
      <h2 class="text-h2 text-northlace-900">What this covers</h2>
      <ul class="mt-6 space-y-3 text-body">
        {pillar.covers.map((item) => <li>{item}</li>)}
      </ul>
    </div>
    <div>
      <h2 class="text-h2 text-northlace-900">Why it matters</h2>
      <p class="mt-6 text-body">{pillar.matters}</p>
    </div>
  </section>

  <section
    class="bg-northlace-50 py-16 md:py-24"
    aria-labelledby="related-case-study"
  >
    <div class="mx-auto max-w-6xl px-6">
      <h2 id="related-case-study" class="text-h2 text-northlace-900">
        Related case study callout
      </h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        {
          related.map((entry) => (
            <article class="rounded-lg border border-northlace-900/10 bg-surface-warm p-6">
              <h3 class="text-h3 text-northlace-900">{entry.data.title}</h3>
              <p class="mt-3 text-body">{entry.data.summary}</p>
              <a
                class="mt-4 inline-flex text-small text-northlace-700 underline"
                href={`/case-studies/${entry.id}`}
              >
                Read case study
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-northlace-900 py-16 text-text-on-dark md:py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-h2">Take the deck to your leadership team</h2>
      <p class="mt-4 max-w-3xl text-body text-northlace-100">
        The modernization sales deck shows how {pillar.name} fits into the Northlace
        Standard, the 90-day pilot, the ROI model, and the assessment-to-scale path.
      </p>
      <a
        class="mt-6 inline-flex rounded-md bg-northlace-300 px-5 py-3 text-small font-medium text-northlace-900"
        href="/resources/modernization-deck"
      >
        Open modernization deck
      </a>
    </div>
  </section>

  <CTABanner
    heading={`Need help with ${pillar.shortName}?`}
    buttonText="Book a discovery call"
    buttonHref="/contact"
  />
</Layout>
