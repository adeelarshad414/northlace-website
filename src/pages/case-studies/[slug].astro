---
import { getCollection } from "astro:content";

import CTABanner from "../../components/CTABanner.astro";
import Layout from "../../layouts/Layout.astro";
import { pillarLabel } from "../../data/services";
import { buildBreadcrumbJsonLd } from "../../lib/seo";

export const getStaticPaths = async () => {
  const entries = (await getCollection("case-studies")).filter(
    (entry) => !entry.data.draft,
  );
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
};

const { entry } = Astro.props;
const canonicalPath = `/case-studies/${entry.id}`;
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
---

<Layout
  title={entry.data.seo.title}
  description={entry.data.seo.description}
  canonicalPath={canonicalPath}
  structuredData={buildBreadcrumbJsonLd(siteUrl, [
    { name: "Home", path: "/" },
    { name: "Case studies", path: "/case-studies" },
    { name: entry.data.title, path: canonicalPath },
  ])}
>
  <section class="bg-northlace-900 py-16 text-text-on-dark md:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <p class="text-small text-northlace-100">{entry.data.clientLabel}</p>
      <h1 class="mt-4 text-h1">{entry.data.title}</h1>
      <p class="mt-5 max-w-3xl text-body text-northlace-100">
        {entry.data.heroMetric.value}
        {entry.data.heroMetric.label}
      </p>
      <p class="mt-4 text-small text-northlace-100">
        {entry.data.pillars.map((pillar) => pillarLabel(pillar)).join(" / ")}
      </p>
    </div>
  </section>

  <section
    class="mx-auto grid max-w-6xl gap-10 px-6 py-16 md:grid-cols-[1fr_1fr] md:py-24"
  >
    <div>
      <h2 class="text-h2 text-northlace-900">Challenge</h2>
      <p class="mt-5 text-body">{entry.data.challenge}</p>
    </div>
    <div>
      <h2 class="text-h2 text-northlace-900">Approach</h2>
      <p class="mt-5 text-body">{entry.data.approach}</p>
    </div>
  </section>

  <section class="bg-northlace-50 py-16 md:py-24" aria-labelledby="outcome">
    <div class="mx-auto max-w-6xl px-6">
      <h2 id="outcome" class="text-h2 text-northlace-900">Outcome</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {
          entry.data.outcomeMetrics.map((metric) => (
            <article class="rounded-lg border border-northlace-900/10 bg-surface-warm p-6">
              <p class="text-h2 text-northlace-900">{metric.value}</p>
              <p class="mt-3 text-body">{metric.label}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CTABanner
    heading="Facing a similar challenge? Let's talk."
    buttonText="Book a discovery call"
    buttonHref="/contact"
  />
</Layout>
