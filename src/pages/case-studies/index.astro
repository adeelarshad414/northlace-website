---
import { getCollection } from "astro:content";

import Layout from "../../layouts/Layout.astro";
import { pillarLabel, servicePillars } from "../../data/services";

const caseStudies = (await getCollection("case-studies")).filter(
  (entry) => !entry.data.draft,
);
---

<Layout
  title="Case studies | Northlace"
  description="Northlace case studies for cloud operations, security, cost, and modernization."
  canonicalPath="/case-studies"
>
  <section class="mx-auto max-w-6xl px-6 py-16 md:py-24">
    <h1 class="text-h1 text-northlace-900">Case studies</h1>
    <p class="mt-5 max-w-3xl text-body">
      Practical examples of how Northlace applies one operating standard across
      delivery, risk, cost, and modernization.
    </p>
    <div
      class="mt-8 flex flex-wrap gap-3"
      data-filter-group
      data-filter-items="[data-case-study-card]"
      data-empty-state="#case-study-empty"
    >
      <button
        class="rounded-md border border-northlace-700 px-4 py-2 text-small text-northlace-700 data-[state=active]:bg-northlace-700 data-[state=active]:text-text-on-dark"
        type="button"
        data-filter-value="all">All</button
      >
      {
        servicePillars.map((pillar) => (
          <button
            class="rounded-md border border-northlace-700 px-4 py-2 text-small text-northlace-700 data-[state=active]:bg-northlace-700 data-[state=active]:text-text-on-dark"
            type="button"
            data-filter-value={pillar.id}
          >
            {pillar.shortName}
          </button>
        ))
      }
    </div>
    <p id="case-study-empty" class="mt-8 text-body" hidden>
      No case studies match that filter.
    </p>
    <div class="mt-8 grid gap-6 md:grid-cols-3">
      {
        caseStudies.map((entry) => (
          <article
            class="rounded-lg border border-northlace-900/10 p-6"
            data-case-study-card
            data-filter-keys={entry.data.pillars.join(" ")}
          >
            <p class="text-small text-northlace-700">
              {entry.data.clientLabel}
            </p>
            <h2 class="mt-2 text-h3 text-northlace-900">{entry.data.title}</h2>
            <p class="mt-3 text-body">
              {entry.data.heroMetric.value} {entry.data.heroMetric.label}
            </p>
            <p class="mt-3 text-small text-northlace-700">
              {entry.data.pillars
                .map((pillar) => pillarLabel(pillar))
                .join(" / ")}
            </p>
            <a
              class="mt-5 inline-flex text-small text-northlace-700 underline"
              href={`/case-studies/${entry.id}`}
            >
              Read detail
            </a>
          </article>
        ))
      }
    </div>
  </section>
  <script>
    import "../../scripts/content-filters";
  </script>
</Layout>
