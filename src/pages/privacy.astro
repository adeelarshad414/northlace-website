---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Privacy | Northlace"
  description="Northlace privacy information."
  canonicalPath="/privacy"
>
  <section class="mx-auto max-w-3xl px-6 py-16 md:py-24">
    <h1 class="text-h1 text-northlace-900">Privacy</h1>
    <p class="mt-5 text-body">
      Northlace collects only the information submitted through contact and
      application forms, and uses it to reply to the request.
    </p>
  </section>
</Layout>
