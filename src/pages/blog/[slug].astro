---
import { getCollection, render } from "astro:content";

import Layout from "../../layouts/Layout.astro";
import { formatDate } from "../../lib/dates";
import { getReadingTime } from "../../lib/reading-time";
import { buildArticleJsonLd, buildBreadcrumbJsonLd } from "../../lib/seo";
import { countWords } from "../../lib/strings";

export const getStaticPaths = async () => {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
};

const { post } = Astro.props;
const { Content } = await render(post);
const readingTime = getReadingTime(countWords(post.body ?? ""));
const posts = await getCollection("blog");
const isBrandLaunch = post.data.tags.includes("personal-brand");
const related = posts
  .filter(
    (candidate) =>
      candidate.id !== post.id &&
      candidate.data.tags.some((tag) => post.data.tags.includes(tag)),
  )
  .slice(0, 3);
const canonicalPath = `/blog/${post.id}`;
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const articleImage = post.data.heroImage ?? "/og/northlace-default.svg";
const structuredData = [
  buildBreadcrumbJsonLd(siteUrl, [
    { name: "Home", path: "/" },
    { name: "Blog", path: "/blog" },
    { name: post.data.title, path: canonicalPath },
  ]),
  buildArticleJsonLd({
    author: post.data.author,
    canonicalPath,
    description: post.data.seo.description,
    image: articleImage,
    publishDate: post.data.publishDate,
    siteUrl,
    title: post.data.title,
  }),
];
---

<Layout
  title={post.data.seo.title}
  description={post.data.seo.description}
  canonicalPath={canonicalPath}
  ogImage={articleImage}
  structuredData={structuredData}
>
  {
    isBrandLaunch ? (
      <article class="mx-auto max-w-3xl px-6 py-16 text-body md:py-24">
        <Content />
        <p class="mt-10 border-t border-northlace-900/10 pt-5 text-small text-northlace-700">
          Published {formatDate(post.data.publishDate)} / {readingTime} min read
          / By {post.data.author}
        </p>
      </article>
    ) : (
      <article class="mx-auto max-w-3xl px-6 py-16 md:py-24">
        <p class="text-small text-northlace-700">
          {formatDate(post.data.publishDate)} / {readingTime} min read
        </p>
        <h1 class="mt-4 text-h1 text-northlace-900">{post.data.title}</h1>
        <p class="mt-4 text-small text-northlace-700">By {post.data.author}</p>
        <div class="prose mt-10 max-w-none text-body">
          <Content />
        </div>
      </article>
    )
  }
  <section
    class="bg-northlace-50 py-16 md:py-24"
    aria-labelledby="related-posts"
  >
    <div class="mx-auto max-w-6xl px-6">
      <h2 id="related-posts" class="text-h2 text-northlace-900">
        Related posts
      </h2>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {
          related.map((item) => (
            <article class="rounded-lg border border-northlace-900/10 bg-surface-warm p-6">
              <h3 class="text-h3 text-northlace-900">{item.data.title}</h3>
              <p class="mt-3 text-body">{item.data.summary}</p>
              <a
                class="mt-4 inline-flex text-small text-northlace-700 underline"
                href={`/blog/${item.id}`}
              >
                Read {item.data.title}
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
