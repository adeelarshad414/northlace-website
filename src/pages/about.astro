---
import CTABanner from "../components/CTABanner.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="About | Northlace"
  description="Northlace builds one operating standard across cloud, security, cost, and modernization work."
  canonicalPath="/about"
>
  <section class="mx-auto max-w-6xl px-6 py-16 md:py-24">
    <h1 class="text-h1 text-northlace-900">About Northlace</h1>
    <p class="mt-5 max-w-3xl text-body">
      Northlace exists to make cloud operations feel less improvised. We bring
      the same standard to delivery, reliability, security, cost, and
      modernization so teams can move without rebuilding the operating model
      every time.
    </p>
  </section>

  <section
    class="bg-northlace-50 py-16 md:py-24"
    aria-labelledby="about-how-we-work"
  >
    <div class="mx-auto max-w-6xl px-6">
      <h2 id="about-how-we-work" class="text-h2 text-northlace-900">
        How we work
      </h2>
      <div class="mt-8 grid gap-6 md:grid-cols-4">
        {
          [
            [
              "Assess",
              "Map systems, risks, cost signals, and team ownership before prescribing work.",
            ],
            [
              "Design",
              "Turn findings into an operating path with clear tradeoffs and review points.",
            ],
            [
              "Implement",
              "Build with the team, document decisions, and keep handover visible.",
            ],
            [
              "Operate",
              "Measure the workflow, tune it, and leave the client team with working habits.",
            ],
          ].map(([title, body]) => (
            <article class="rounded-lg border border-northlace-900/10 bg-surface-warm p-5">
              <h3 class="text-h3 text-northlace-900">{title}</h3>
              <p class="mt-3 text-small">{body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section
    class="mx-auto max-w-6xl px-6 py-16 md:py-24"
    aria-labelledby="leadership"
  >
    <h2 id="leadership" class="text-h2 text-northlace-900">
      Leadership and team
    </h2>
    <div class="mt-8 rounded-lg border border-northlace-900/10 p-6">
      <h3 class="text-h3 text-northlace-900">Northlace delivery leadership</h3>
      <p class="mt-3 text-body">
        Public leadership bios and approved team photography will be added after
        final sign-off. Until then, this section keeps the intended structure
        without inventing personal claims.
      </p>
    </div>
  </section>

  <section class="bg-northlace-50 py-16 md:py-24" aria-labelledby="values">
    <div class="mx-auto max-w-6xl px-6">
      <h2 id="values" class="text-h2 text-northlace-900">Values</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        {
          [
            [
              "We page ourselves before we page you",
              "We own the operating standard we recommend.",
            ],
            [
              "We make the invisible visible",
              "Risk, cost, and reliability need signals that decision makers can read.",
            ],
            [
              "We leave teams stronger",
              "A handover is only done when the client team can keep moving.",
            ],
            [
              "We explain the acronym first",
              "Technical depth should not require insider language to be useful.",
            ],
          ].map(([title, body]) => (
            <article class="rounded-lg border border-northlace-900/10 bg-surface-warm p-6">
              <h3 class="text-h3 text-northlace-900">{title}</h3>
              <p class="mt-3 text-body">{body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CTABanner
    heading="Want to build with Northlace?"
    buttonText="We're hiring"
    buttonHref="/careers"
  />
</Layout>
