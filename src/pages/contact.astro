---
import ContactForm from "../components/ContactForm.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact | Northlace"
  description="Talk to Northlace about cloud, DevOps, security, cost, and modernization work."
  canonicalPath="/contact"
>
  <section
    class="mx-auto grid max-w-6xl gap-10 px-6 py-16 md:grid-cols-[1fr_1.2fr] md:py-24"
  >
    <div>
      <h1 class="text-h1 text-northlace-900">Let's talk</h1>
      <p class="mt-5 text-body">
        Tell us what you are trying to improve. We reply within 1-2 business
        days and will route the conversation to the right technical lead.
      </p>
      <div class="mt-8 rounded-lg border border-northlace-900/10 p-5">
        <h2 class="text-h3 text-northlace-900">Company info</h2>
        <p class="mt-3 text-body">
          General inquiries: <a
            class="text-northlace-700 underline"
            href="mailto:hello@northlace.example">hello@northlace.example</a
          >
        </p>
      </div>
    </div>
    <ContactForm />
  </section>
</Layout>
