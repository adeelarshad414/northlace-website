{
  "name": "northlace-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "brand:build": "node scripts/brand/build.mjs",
    "deck:build": "node scripts/deck/build-sales-deck.mjs",
    "typecheck": "ASTRO_TELEMETRY_DISABLED=1 astro check --tsconfig ./tsconfig.json",
    "lint": "eslint . --ext .astro,.ts,.js,.mjs,.cjs --max-warnings=0",
    "lint:content": "node scripts/lint-metric-placeholders.mjs",
    "lint:production-content": "node scripts/check-production-content.mjs",
    "report:content-markers": "node scripts/report-content-markers.mjs",
    "security:audit": "npm audit --audit-level=high",
    "security:secrets": "node scripts/secret-scan.mjs",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test --grep-invert @a11y",
    "test:a11y": "playwright test tests/e2e/a11y.spec.ts",
    "lhci": "lhci autorun --config=./lighthouserc.cjs",
    "lhci:brand": "lhci autorun --config=./lighthouserc.brand.cjs",
    "lhci:resources": "lhci autorun --config=./lighthouserc.resources.cjs",
    "test:full": "npm run brand:build && npm run deck:build && npm run lint && npm run lint:content && npm run report:content-markers && npm run security:secrets && npm run security:audit && npm run format:check && npm run typecheck && npm run test && npm run build && npm run lint:production-content && npm run test:e2e && npm run test:a11y && npm run lhci && npm run lhci:brand && npm run lhci:resources"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "astro": "^7.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@axe-core/playwright": "^4.10.0",
    "@lhci/cli": "^0.15.0",
    "@playwright/test": "^1.49.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "astro-eslint-parser": "^1.1.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^1.3.1",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "postcss": "^8.4.49",
    "pptxgenjs": "^4.0.1",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "tmp": "^0.2.7"
  }
}
